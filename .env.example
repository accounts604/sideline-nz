# Database (Neon, Supabase, or any PostgreSQL provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# GoHighLevel (GHL)
SIDELINE_GHL_API_KEY=
SIDELINE_GHL_LOCATION_ID=
GHL_PRODUCT_WEBHOOK_SECRET=

# Shopify Storefront API
VITE_SHOPIFY_STORE_URL=your-store.myshopify.com
VITE_SHOPIFY_TOKEN=

# Gemini API (for mockup generation — Google Cloud Console)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Authentication
JWT_SECRET=change-this-to-a-random-string

# Vercel Blob (file uploads)
BLOB_READ_WRITE_TOKEN=

# Admin seed (only needed for scripts/seed-admin.ts)
# ADMIN_EMAIL=romero@sidelinenz.com
# ADMIN_PASSWORD=changeme123

# Email (optional — defaults to console logging)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=

# Mockup Engine — AI-generated uniform mockups
GEMINI_API_KEY=                    # Google Gemini API key for image generation
ELEVENLABS_API_KEY=                # ElevenLabs API key for voiceover
ELEVENLABS_VOICE_ID=               # Optional: specific voice ID (defaults to Rachel)

# ClickUp (optional — for mockup follow-up task creation)
CLICKUP_API_KEY=
CLICKUP_MOCKUP_LIST_ID=

# Optional: Site URL for og:image meta tags (auto-detected on Vercel)
# VITE_SITE_URL=https://sidelinenz.com
BASE_URL=https://sidelinenz.com
